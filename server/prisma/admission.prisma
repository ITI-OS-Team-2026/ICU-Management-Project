enum AdmissionStatus {
  ACTIVE
  DISCHARGED
  ARCHIVED
}

model Admission {
  id                     String          @id @default(uuid())
  patientId              String          @map("patient_id")
  bedId                  String          @map("bed_id")
  doctorId               String          @map("doctor_id")
  admissionReason        String?         @map("admission_reason") @db.Text
  placeOfTransfer        String?         @map("place_of_transfer") @db.Text
  transferDoctorName     String?         @map("transfer_doctor_name") @db.Text
  chiefComplaint         String?         @map("chief_complaint") @db.Text
  symptomsRelatedSystem  String?         @map("symptoms_related_system") @db.Text
  symptomsOtherSystems   String?         @map("symptoms_other_systems") @db.Text
  previousInvestigations String?         @map("previous_investigations") @db.Text
  previousTreatments     String?         @map("previous_treatments") @db.Text
  provisionalDiagnosis   String?         @map("provisional_diagnosis") @db.Text
  status                 AdmissionStatus @default(ACTIVE)
  admittedAt             DateTime        @default(now()) @map("admitted_at")
  dischargedAt           DateTime?       @map("discharged_at")
  isArchived             Boolean         @default(false) @map("is_archived")
  archivedAt             DateTime?       @map("archived_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  patient   Patient          @relation(fields: [patientId], references: [id])
  bed       Bed              @relation(fields: [bedId], references: [id])
  doctor    User             @relation("AdmissionDoctor", fields: [doctorId], references: [id])
  nurses    AdmissionNurse[]
  diagnoses Diagnosis[]
  vitalSigns     VitalSign[]
  medications    Medication[]
  investigationOrders InvestigationOrder[]
  labResults          LabResult[]
  clinicalExaminations ClinicalExamination[]
  clinicalNotes       ClinicalNote[]
  nursingNotes        NursingNote[]
  followUps           FollowUp[]

  @@index([patientId])
  @@index([status])
  @@index([doctorId])
  @@index([bedId])
  @@map("admissions")
}

model AdmissionNurse {
  id           String    @id @default(uuid())
  admissionId  String    @map("admission_id")
  nurseId      String    @map("nurse_id")
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  unassignedAt DateTime? @map("unassigned_at")
  isArchived   Boolean   @default(false) @map("is_archived")
  archivedAt   DateTime? @map("archived_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  nurse     User      @relation("AdmissionNurseAssignments", fields: [nurseId], references: [id])

  @@index([admissionId])
  @@index([nurseId])
  @@map("admission_nurses")
}
