// Lab results — test results recorded against an admission.
// `abnormal` is a plain Boolean (not an enum) per the ERD, set by the recording clinician.

model LabResult {
  id           String   @id @default(uuid())
  admissionId  String   @map("admission_id")
  recordedById String   @map("recorded_by")
  testName     String   @map("test_name") @db.VarChar(255)
  resultValue  String   @map("result_value") @db.Text
  abnormal     Boolean  @default(false)
  recordedAt   DateTime @default(now()) @map("recorded_at")
  isArchived   Boolean  @default(false) @map("is_archived")
  archivedAt   DateTime? @map("archived_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  recordedBy User      @relation(fields: [recordedById], references: [id])

  @@index([admissionId])
  @@index([recordedById])
  @@index([recordedAt])
  @@map("lab_results")
}
