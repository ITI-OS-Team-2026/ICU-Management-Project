{
  "info": {
    "name": "SmartCare ICU - Diagnoses (Wave 4)",
    "description": "Diagnoses endpoints (Wave 4). Run Setup first to get patient/bed/admission fixtures.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "nurse_email",
      "value": "nurse@smartcare.icu"
    },
    {
      "key": "resident_email",
      "value": "resident@smartcare.icu"
    },
    {
      "key": "specialist_email",
      "value": "specialist@smartcare.icu"
    },
    {
      "key": "shared_password",
      "value": "SuperSecurePassword2026!"
    },
    {
      "key": "patient_id",
      "value": ""
    },
    {
      "key": "bed_id",
      "value": ""
    },
    {
      "key": "doctor_id",
      "value": ""
    },
    {
      "key": "admission_id",
      "value": ""
    },
    {
      "key": "diagnosis_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Login Specialist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{specialist_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('doctor_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Patient Fixture",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mrn\": \"PM-DIAG-{{$timestamp}}\",\n  \"name\": \"Diagnosis Patient\",\n  \"age\": 50\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('patient_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin (for bed)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@smartcare.icu\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Bed Fixture",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/beds",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "beds"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bed_number\": \"PM-DIAG-BED-{{$timestamp}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('bed_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Resident (for admission)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{resident_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Admission Fixture",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"{{patient_id}}\",\n  \"bed_id\": \"{{bed_id}}\",\n  \"doctor_id\": \"{{doctor_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('admission_id', pm.response.json().id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. Diagnoses",
      "item": [
        {
          "name": "Login Resident",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{resident_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Diagnosis",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/diagnoses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "diagnoses"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"condition_name\": \"Asthma\",\n  \"status\": \"ACTIVE\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const res = pm.response.json();",
                  "pm.test('Returns diagnosed_by object', () => pm.expect(res).to.have.property('diagnosedBy'));",
                  "pm.test('Returns diagnosed_at', () => pm.expect(res).to.have.property('diagnosedAt'));",
                  "pm.collectionVariables.set('diagnosis_id', res.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Diagnoses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/diagnoses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "diagnoses"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Returns an array', () => pm.expect(res).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Diagnosis (Append-Only)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/diagnoses/{{diagnosis_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "diagnoses",
                "{{diagnosis_id}}"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RESOLVED\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const res = pm.response.json();",
                  "pm.test('Status is updated to RESOLVED', () => pm.expect(res.status).to.eql('RESOLVED'));",
                  "pm.test('New ID generated', () => pm.expect(res.id).to.not.eql(pm.collectionVariables.get('diagnosis_id')));",
                  "pm.collectionVariables.set('diagnosis_id', res.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete (Archive) Diagnosis",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/diagnoses/{{diagnosis_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "diagnoses",
                "{{diagnosis_id}}"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Auth Edge Cases",
      "item": [
        {
          "name": "Login Nurse",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{nurse_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Nurse Cannot Create Diagnosis (403)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/diagnoses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "diagnoses"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"condition_name\": \"Nurse Attempt\",\n  \"status\": \"ACTIVE\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Nurse Cannot Update Diagnosis (403)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/diagnoses/{{diagnosis_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "diagnoses",
                "{{diagnosis_id}}"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RESOLVED\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Nurse Cannot Delete Diagnosis (403)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/diagnoses/{{diagnosis_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "diagnoses",
                "{{diagnosis_id}}"
              ]
            },
            "description": ""
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}