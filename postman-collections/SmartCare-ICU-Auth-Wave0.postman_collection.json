{
  "info": {
    "name": "SmartCare ICU - Auth (Wave 0)",
    "description": "Auth system verification: login (all roles), validation, lockout, session, logout. Import and hit 'Run collection' to execute everything with assertions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "admin_email",
      "value": "admin@smartcare.icu"
    },
    {
      "key": "nurse_email",
      "value": "nurse@smartcare.icu"
    },
    {
      "key": "resident_email",
      "value": "resident@smartcare.icu"
    },
    {
      "key": "specialist_email",
      "value": "specialist@smartcare.icu"
    },
    {
      "key": "shared_password",
      "value": "SuperSecurePassword2026!"
    }
  ],
  "item": [
    {
      "name": "0. Session - Unauthenticated Check (must run first, before any login)",
      "item": [
        {
          "name": "Me Without Login (should fail)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. Login - Happy Path",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role is SYSTEM_ADMIN', () => pm.expect(pm.response.json().role).to.eql('SYSTEM_ADMIN'));",
                  "pm.test('No password hash or token leaked', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.not.have.property('passwordHash');",
                  "  pm.expect(body).to.not.have.property('token');",
                  "});",
                  "pm.test('Cookie is set and HttpOnly', () => {",
                  "  const cookieHeader = pm.response.headers.get('Set-Cookie');",
                  "  pm.expect(cookieHeader).to.not.be.null;",
                  "  pm.expect(cookieHeader.toLowerCase()).to.include('httponly');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Nurse",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{nurse_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role is ICU_NURSE', () => pm.expect(pm.response.json().role).to.eql('ICU_NURSE'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Resident",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{resident_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role is MEDICAL_RESIDENT', () => pm.expect(pm.response.json().role).to.eql('MEDICAL_RESIDENT'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Specialist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{specialist_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role is ICU_SPECIALIST', () => pm.expect(pm.response.json().role).to.eql('ICU_SPECIALIST'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Case-Insensitive Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ADMIN@SMARTCARE.ICU\",\n  \"password\": \"{{shared_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 despite uppercase email', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Login - Validation Errors",
      "item": [
        {
          "name": "Empty Body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Missing Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Invalid Email Format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"{{shared_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Login - Wrong Credentials",
      "item": [
        {
          "name": "Wrong Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"wrong-password-123\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Generic message', () => pm.expect(pm.response.json().message).to.eql('Invalid credentials'));",
                  "pm.collectionVariables.set('wrong_password_message', pm.response.json().message);"
                ]
              }
            }
          ]
        },
        {
          "name": "Nonexistent Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@smartcare.icu\",\n  \"password\": \"anything123\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Message is byte-identical to wrong-password message', () => {",
                  "  const expected = pm.collectionVariables.get('wrong_password_message');",
                  "  pm.expect(pm.response.json().message).to.eql(expected);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Session (auth-me)",
      "item": [
        {
          "name": "Login Then Me (should match)",
          "item": [
            {
              "name": "Step 1 - Login Nurse",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{nurse_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
                },
                "url": "{{base_url}}/auth/login"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Login succeeded', () => pm.response.to.have.status(200));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Step 2 - Me (uses same cookie jar)",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/auth/me"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                      "pm.test('Role matches logged-in nurse', () => pm.expect(pm.response.json().role).to.eql('ICU_NURSE'));",
                      "pm.test('No password hash in me response', () => {",
                      "  pm.expect(pm.response.json()).to.not.have.property('passwordHash');",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "5. Logout",
      "item": [
        {
          "name": "Logout Without Session (should fail)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Then Logout Then Me",
          "item": [
            {
              "name": "Step 1 - Login Specialist",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{specialist_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
                },
                "url": "{{base_url}}/auth/login"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Login succeeded', () => pm.response.to.have.status(200));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Step 2 - Logout",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/auth/logout"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Step 3 - Me After Logout (should fail)",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/auth/me"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test('Status is 401 - session cleared', () => pm.response.to.have.status(401));"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
