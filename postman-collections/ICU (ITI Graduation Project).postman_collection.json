				{
					"name": "1. Login - Happy Path",
					"item": [
						{
							"name": "Login Admin",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"pm.test('Status is 200', () => pm.response.to.have.status(200));",
											"pm.test('Role is SYSTEM_ADMIN', () => pm.expect(pm.response.json().role).to.eql('SYSTEM_ADMIN'));",
											"pm.test('No password hash or token leaked', () => {",
											"  const body = pm.response.json();",
											"  pm.expect(body).to.not.have.property('passwordHash');",
											"  pm.expect(body).to.not.have.property('token');",
											"});",
											"pm.test('Cookie is set and HttpOnly', () => {",
											"  const cookieHeader = pm.response.headers.get('Set-Cookie');",
											"  pm.expect(cookieHeader).to.not.be.null;",
											"  pm.expect(cookieHeader.toLowerCase()).to.include('httponly');",
											"});"
										],
										"type": "text/javascript",
										"packages": {},
										"requests": {}
									}
								}
							],
