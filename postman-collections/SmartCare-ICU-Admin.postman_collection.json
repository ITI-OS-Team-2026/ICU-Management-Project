{
  "info": {
    "name": "SmartCare ICU - Admin",
    "description": "Admin Users and Beds endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john.doe@smartcare.icu\",\n  \"role\": \"nurse\"\n}"
            },
            "url": "{{base_url}}/admin/users"
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/users?role=nurse&status=ACTIVE",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                {
                  "key": "role",
                  "value": "nurse"
                },
                {
                  "key": "status",
                  "value": "ACTIVE"
                }
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/users/:id"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"specialist\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": "{{base_url}}/admin/users/:id"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/users/:id"
          }
        }
      ]
    },
    {
      "name": "Beds",
      "item": [
        {
          "name": "Create Bed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bed_number\": \"ICU-01\"\n}"
            },
            "url": "{{base_url}}/admin/beds"
          }
        },
        {
          "name": "Get Beds",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/beds?status=AVAILABLE",
              "host": ["{{base_url}}"],
              "path": ["admin", "beds"],
              "query": [
                {
                  "key": "status",
                  "value": "AVAILABLE"
                }
              ]
            }
          }
        },
        {
          "name": "Update Bed",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"OCCUPIED\"\n}"
            },
            "url": "{{base_url}}/admin/beds/:id"
          }
        }
      ]
    }
  ]
}
