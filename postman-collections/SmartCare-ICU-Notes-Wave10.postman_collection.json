{
  "info": {
    "name": "SmartCare ICU - Notes (Wave 10)",
    "description": "Clinical and Nursing Notes endpoints (Wave 10). Run Setup first to get fixtures.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "nurse_email",
      "value": "nurse@smartcare.icu"
    },
    {
      "key": "resident_email",
      "value": "resident@smartcare.icu"
    },
    {
      "key": "specialist_email",
      "value": "specialist@smartcare.icu"
    },
    {
      "key": "shared_password",
      "value": "SuperSecurePassword2026!"
    },
    {
      "key": "patient_id",
      "value": ""
    },
    {
      "key": "bed_id",
      "value": ""
    },
    {
      "key": "doctor_id",
      "value": ""
    },
    {
      "key": "admission_id",
      "value": ""
    },
    {
      "key": "clinical_note_id",
      "value": ""
    },
    {
      "key": "nursing_note_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Login Specialist (Retrieve Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{specialist_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('doctor_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Insert Dummy Patient into [patients] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mrn\": \"PM-NOTE-{{$timestamp}}\",\n  \"name\": \"Note Patient\",\n  \"age\": 50\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('patient_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin (Retrieve Token for Bed Creation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@smartcare.icu\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Insert Dummy Bed into [beds] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/beds",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "beds"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bed_number\": \"NOTE-{{$timestamp}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('bed_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Resident (Retrieve Token for Admission)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{resident_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Insert Dummy Admission into [admissions] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"{{patient_id}}\",\n  \"bed_id\": \"{{bed_id}}\",\n  \"doctor_id\": \"{{doctor_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('admission_id', pm.response.json().id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. Clinical Notes",
      "item": [
        {
          "name": "Login Resident (Retrieve Token for Clinical Notes)",
          "request": {
            "method": "POST",
            "header": [
