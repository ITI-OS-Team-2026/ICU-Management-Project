        },
        {
          "name": "Insert Clinical Note into [clinical_notes] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/notes/clinical",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "notes",
                "clinical"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Patient is stable. No signs of distress today.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('clinical_note_id', pm.response.json().data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Select from [clinical_notes] table",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/notes/clinical",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "notes",
                "clinical"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
