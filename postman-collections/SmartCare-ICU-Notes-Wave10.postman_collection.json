    },
    {
      "name": "3. Deletion (Auth Edge Cases)",
      "item": [
        {
          "name": "Attempt Delete [nursing_notes] as Nurse (403 Forbidden)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/notes/nursing/{{nursing_note_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "notes",
                "nursing",
                "{{nursing_note_id}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Attempt Delete [clinical_notes] as Nurse (403 Forbidden)",
          "request": {
            "method": "DELETE",
