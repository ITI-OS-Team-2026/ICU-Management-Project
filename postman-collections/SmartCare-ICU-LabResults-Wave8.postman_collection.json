                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{resident_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login Resident - 200', ()=>pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET - 200 List labs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/labs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "labs"
              ]
            },
            "description": "Lists lab results for the admission. Verifies array response and recordedBy join. Admission was discharged in section 1 but GET does not check admission status — only existence."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('GET Labs - 200', ()=>pm.response.to.have.status(200));",
                  "const r=pm.response.json();",
                  "pm.test('Response is array', ()=>pm.expect(r).to.be.an('array'));",
                  "pm.test('Has at least 2 results', ()=>pm.expect(r.length).to.be.at.least(2));",
                  "if(r.length>0){",
                  "  pm.test('Each item has recordedBy', ()=>pm.expect(r[0]).to.have.property('recordedBy'));",
                  "  pm.test('recordedBy has id', ()=>pm.expect(r[0].recordedBy).to.have.property('id'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET - 200 Filter ?abnormal=true",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/labs?abnormal=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "labs"
              ],
              "query": [
                {
                  "key": "abnormal",
                  "value": "true"
                }
              ]
            },
            "description": "Only abnormal results should be returned."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('GET abnormal filter - 200', ()=>pm.response.to.have.status(200));",
                  "const r=pm.response.json();",
                  "pm.test('Response is array', ()=>pm.expect(r).to.be.an('array'));",
                  "pm.test('All results are abnormal', ()=>r.forEach(i=>pm.expect(i.abnormal).to.eql(true)));",
                  "pm.test('Contains Potassium result', ()=>pm.expect(r.some(i=>i.testName==='Potassium')).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET - 200 Date range filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/labs?from={{today_date}}&to={{tomorrow_date}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "labs"
              ],
              "query": [
                {
                  "key": "from",
                  "value": "{{today_date}}"
                },
                {
                  "key": "to",
                  "value": "{{tomorrow_date}}"
                }
              ]
            },
            "description": "Filters by date range. Pre-request computes tomorrow for the upper bound."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const d=new Date(); d.setDate(d.getDate()+1);",
                  "pm.collectionVariables.set('tomorrow_date', d.toISOString().split('T')[0]);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('GET date filter - 200', ()=>pm.response.to.have.status(200));",
                  "const r=pm.response.json();",
                  "pm.test('Response is array', ()=>pm.expect(r).to.be.an('array'));",
                  "pm.test('Results returned within range', ()=>pm.expect(r.length).to.be.at.least(1));"
                ]
              }
            }
          ]
        },
        {
