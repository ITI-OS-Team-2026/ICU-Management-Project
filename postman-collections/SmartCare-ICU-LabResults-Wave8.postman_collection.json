{
  "info": {
    "name": "SmartCare ICU - Lab Results (Wave 8)",
    "description": "Lab Results endpoints (Wave 8 — feature/lab-results branch). Run '0. Setup' first — it creates patient + bed + ACTIVE admission fixtures and stores IDs as collection variables. Auth is handled via Postman's cookie jar (login requests set the HttpOnly JWT cookie automatically).\n\nCleanup: Fixtures use prefixes PM-LAB- (MRN) and LAB- (bed number) for easy identification and purging. The admission is discharged during testing (section 1, 409 test). Lab results are soft-archived via DELETE.\n\nKNOWN GAP: The ?include_archived=true query parameter is NOT implemented in the getLabResults service — archived labs are always excluded from GET results. See section 3 for details.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "nurse_email",
      "value": "nurse@smartcare.icu"
    },
    {
      "key": "resident_email",
      "value": "resident@smartcare.icu"
    },
    {
      "key": "specialist_email",
      "value": "specialist@smartcare.icu"
    },
    {
      "key": "shared_password",
      "value": "SuperSecurePassword2026!"
    },
    {
      "key": "patient_id",
      "value": ""
    },
    {
      "key": "bed_id",
      "value": ""
    },
    {
      "key": "doctor_id",
      "value": ""
    },
    {
      "key": "admission_id",
      "value": ""
    },
    {
      "key": "lab_id",
      "value": ""
    },
    {
      "key": "lab_id_abnormal",
      "value": ""
    },
    {
      "key": "today_date",
      "value": ""
    },
    {
      "key": "tomorrow_date",
      "value": ""
    }
  ],
  "item": [
    {
