        {
          "name": "POST - 201 Success (Resident records lab)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/labs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "labs"
              ]
            },
            "description": "Happy path: resident records a normal lab result. Captures lab_id and today_date for later filtering.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"test_name\": \"Hemoglobin\",\n  \"result_value\": \"14.2 g/dL\",\n  \"abnormal\": false\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('POST Lab - 201', ()=>pm.response.to.have.status(201));",
                  "const r=pm.response.json();",
                  "pm.test('Returns testName', ()=>pm.expect(r.testName).to.eql('Hemoglobin'));",
                  "pm.test('Returns resultValue', ()=>pm.expect(r.resultValue).to.eql('14.2 g/dL'));",
                  "pm.test('abnormal is false', ()=>pm.expect(r.abnormal).to.eql(false));",
                  "pm.test('Has recordedBy', ()=>pm.expect(r.recordedBy).to.have.property('id'));",
                  "pm.test('Has id', ()=>pm.expect(r).to.have.property('id'));",
                  "pm.collectionVariables.set('lab_id', r.id);",
                  "pm.collectionVariables.set('today_date', new Date().toISOString().split('T')[0]);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST - 201 Abnormal lab (for filter test)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/labs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "labs"
              ]
            },
            "description": "Creates a second lab with abnormal=true for GET filter testing.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"test_name\": \"Potassium\",\n  \"result_value\": \"6.1 mmol/L\",\n  \"abnormal\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('POST Abnormal Lab - 201', ()=>pm.response.to.have.status(201));",
                  "const r=pm.response.json();",
                  "pm.test('abnormal is true', ()=>pm.expect(r.abnormal).to.eql(true));",
                  "pm.collectionVariables.set('lab_id_abnormal', r.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST - 400 Missing test_name",
