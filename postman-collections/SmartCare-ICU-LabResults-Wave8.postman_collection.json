    {
      "name": "2. GET /admissions/:id/labs",
      "item": [
        {
          "name": "Login Resident (restore session)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
