          ]
        },
        {
          "name": "POST - 409 Inactive admission",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/labs",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "labs"
              ]
            },
            "description": "Pre-request discharges the admission. Service then rejects with 409 because status !== ACTIVE.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"test_name\": \"WBC\",\n  \"result_value\": \"6.5\",\n  \"abnormal\": false\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const base = pm.collectionVariables.get('base_url');",
                  "const admId = pm.collectionVariables.get('admission_id');",
                  "pm.sendRequest({",
                  "  url: `${base}/admissions/${admId}/discharge`,",
                  "  method: 'PATCH',",
                  "  header: { 'Content-Type': 'application/json' }",
                  "}, (err, res) => {});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('POST (inactive admission) - 409', ()=>pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        }
      ]
