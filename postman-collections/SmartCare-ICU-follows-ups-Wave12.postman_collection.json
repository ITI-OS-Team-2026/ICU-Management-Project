{
  "info": {
    "name": "SmartCare ICU - Follow-ups (Wave 12)",
    "description": "SOAP Follow-up endpoints (Wave 12). Setup creates patient, bed, and active admission.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "nurse_email",
      "value": "nurse@smartcare.icu"
    },
    {
      "key": "resident_email",
      "value": "resident@smartcare.icu"
    },
    {
      "key": "specialist_email",
      "value": "specialist@smartcare.icu"
    },
    {
      "key": "shared_password",
      "value": "SuperSecurePassword2026!"
    },
    {
      "key": "patient_id",
      "value": ""
    },
    {
      "key": "bed_id",
      "value": ""
    },
    {
      "key": "doctor_id",
      "value": ""
    },
    {
      "key": "admission_id",
      "value": ""
    },
    {
      "key": "follow_up_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Login Specialist (Retrieve Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{specialist_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('doctor_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Insert Dummy Patient into [patients] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/patients",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "patients"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mrn\": \"PM-SOAP-{{$timestamp}}\",\n  \"name\": \"SOAP Patient\",\n  \"age\": 45\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('patient_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin (Retrieve Token for Bed Creation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@smartcare.icu\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Insert Dummy Bed into [beds] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admin/beds",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "beds"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bed_number\": \"SOAP-{{$timestamp}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('bed_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Specialist (Retrieve Token for Admission)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{specialist_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Insert Dummy Admission into [admissions] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient_id\": \"{{patient_id}}\",\n  \"bed_id\": \"{{bed_id}}\",\n  \"doctor_id\": \"{{doctor_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('admission_id', pm.response.json().id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "1. SOAP Follow-ups",
      "item": [
        {
          "name": "Login Resident (Retrieve Token for SOAP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{resident_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Insert SOAP Follow-up into [follow_ups] table",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/follow-ups",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "follow-ups"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subjective\": \"Patient feels less pain.\",\n  \"objective\": \"Temp is 36.8C, pulse is 80 bpm.\",\n  \"assessment\": \"Post-op recovery on track.\",\n  \"plan\": \"Wean off oxygen support.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('follow_up_id', pm.response.json().data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Select SOAP Follow-ups from [follow_ups] table",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/follow-ups",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "follow-ups"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contains at least one item', () => pm.expect(pm.response.json().results).to.be.at.least(1));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Nurse (Retrieve Token for SOAP Verification)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{nurse_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Select SOAP Follow-ups as Nurse (Allowed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/follow-ups",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "follow-ups"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Try to Insert SOAP Follow-up as Nurse (Forbidden)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/follow-ups",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "follow-ups"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subjective\": \"Nurse trying to log SOAP\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Specialist (Retrieve Token for Deletion)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{specialist_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Soft-archive SOAP Follow-up from [follow_ups] table",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/follow-ups/{{follow_up_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "follow-ups",
                "{{follow_up_id}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Deletion (Count is 0)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admissions/{{admission_id}}/follow-ups",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admissions",
                "{{admission_id}}",
                "follow-ups"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Results count is 0', () => pm.expect(pm.response.json().results).to.equal(0));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
