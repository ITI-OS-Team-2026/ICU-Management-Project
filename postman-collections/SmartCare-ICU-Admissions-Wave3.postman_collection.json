                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "4. Auth Edge Cases",
      "item": [
        {
          "name": "Login Resident",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{resident_email}}\",\n  \"password\": \"{{shared_password}}\"\n}"
            },
            "url": "{{base_url}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Resident Cannot Assign Nurses (403)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nurse_id\": \"{{nurse_id}}\"\n}"
            },
            "url": "{{base_url}}/admissions/{{admission_id}}/nurses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 403 or 404', () => {",
                  "  pm.expect([403, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Nurse - Cannot Discharge (403)",
          "item": [
            {
              "name": "Login Nurse",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
